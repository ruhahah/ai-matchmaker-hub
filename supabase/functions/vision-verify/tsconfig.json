{
  "compilerOptions": {
    "allowJs": true,
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "target": "ES2020",
    "module": "ES2020",
    "typeRoots": ["./", "./node_modules/@types"]
  },
  "include": ["**/*.ts", "**/*.d.ts"],
  "exclude": ["node_modules"]
}
